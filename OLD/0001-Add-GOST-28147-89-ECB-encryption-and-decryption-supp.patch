+const struct nettle_cipher nettle_gost28147 =
+  { "gost28147", sizeof(struct gost28147_ctx),
+    GOST28147_BLOCK_SIZE, GOST28147_KEY_SIZE,
+    (nettle_set_key_func *) gost28147_set_key,
+    (nettle_set_key_func *) gost28147_set_key,
