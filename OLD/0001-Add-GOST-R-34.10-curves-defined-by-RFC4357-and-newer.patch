index ad31561e..7a9c1eaa 100644
--- a/.gitignore
+++ b/.gitignore
@@ -49,6 +49,11 @@ core
 /ecc-384.h
 /ecc-521.h
 /ecc-25519.h
+/ecc-gost256cpa.h
