+
+#define KUZNYECHIK_KEY_SIZE 32
+#define KUZNYECHIK_SUBKEYS_SIZE (16 * 10)
+#define KUZNYECHIK_BLOCK_SIZE 16
+
+struct kuznyechik_ctx
+{
+  uint8_t key[KUZNYECHIK_SUBKEYS_SIZE];
+  uint8_t dekey[KUZNYECHIK_SUBKEYS_SIZE];
